BEYOND_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/beyond_ai
BEYOND_DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/beyond_ai
BEYOND_REDIS_URL=redis://localhost:6379/0
BEYOND_JWT_SECRET_KEY=change-me-in-production
BEYOND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://beyond-ai-ten.vercel.app"]
BEYOND_DEBUG=false

# Google Workspace (GWS) - Sheets via GAS
BEYOND_GAS_WEB_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
BEYOND_GAS_API_KEY=your-gas-api-key
BEYOND_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Google OAuth2 (user login)
BEYOND_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
BEYOND_GOOGLE_CLIENT_SECRET=your-client-secret
BEYOND_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# AI Providers
BEYOND_GEMINI_API_KEY=your-gemini-api-key
BEYOND_CLAUDE_API_KEY=your-claude-api-key
